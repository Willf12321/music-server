<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Music Server</title>
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background: #111;
            color: #eee;
            font-family: ui-sans-serif, system-ui, sans-serif;
            min-height: 100vh;
            padding: 3rem 1rem 10rem;
        }

        /* ── Search ── */

        .search-bar {
            display: flex;
            gap: 0.5rem;
            max-width: 640px;
            margin: 0 auto 2.5rem;
        }

        .search-bar input {
            flex: 1;
            padding: 0.65rem 1rem;
            border-radius: 6px;
            border: 1px solid #333;
            background: #1e1e1e;
            color: #eee;
            font-size: 1rem;
            outline: none;
        }

        .search-bar input:focus { border-color: #555; }

        .search-bar button {
            padding: 0.65rem 1.25rem;
            border-radius: 6px;
            border: none;
            background: #2a2a2a;
            color: #eee;
            font-size: 1rem;
            cursor: pointer;
        }

        .search-bar button:hover { background: #333; }

        /* ── Results ── */

        .results {
            max-width: 640px;
            margin: 0 auto;
            list-style: none;
        }

        .track {
            display: flex;
            align-items: center;
            padding: 0.85rem 0;
            border-bottom: 1px solid #1e1e1e;
            gap: 1rem;
        }

        .track-info { flex: 1; min-width: 0; }

        .track-title {
            font-size: 1rem;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .track-meta {
            font-size: 0.8rem;
            color: #777;
            margin-top: 0.2rem;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .track-duration {
            font-size: 0.85rem;
            color: #555;
            flex-shrink: 0;
        }

        .source-badge {
            display: inline-block;
            font-size: 0.6rem;
            font-weight: 600;
            padding: 0.1rem 0.35rem;
            border-radius: 3px;
            text-transform: uppercase;
            letter-spacing: 0.06em;
            margin-top: 0.2rem;
        }

        .source-badge.tidal   { background: #0a2030; color: #4a9aba; }
        .source-badge.youtube { background: #2a0a0a; color: #c44; }

        .track-actions {
            display: flex;
            gap: 0.4rem;
            flex-shrink: 0;
        }

        .no-results {
            max-width: 640px;
            margin: 0 auto;
            color: #555;
            font-size: 0.95rem;
        }

        /* ── Tabs ── */

        .tabs {
            max-width: 640px;
            margin: 0 auto 1.5rem;
            display: flex;
            gap: 0.25rem;
        }

        .tab {
            padding: 0.4rem 0.9rem;
            border-radius: 5px;
            border: none;
            background: transparent;
            color: #555;
            font-size: 0.85rem;
            cursor: pointer;
        }

        .tab:hover { color: #aaa; }
        .tab.active { background: #2a2a2a; color: #eee; }

        /* ── Section heading ── */

        .section-heading {
            max-width: 640px;
            margin: 0 auto 0.5rem;
            font-size: 0.7rem;
            color: #555;
            text-transform: uppercase;
            letter-spacing: 0.08em;
            padding-bottom: 0.4rem;
            border-bottom: 1px solid #1e1e1e;
        }

        /* ── Album row ── */

        .album {
            display: flex;
            align-items: center;
            padding: 0.85rem 0;
            border-bottom: 1px solid #1e1e1e;
            gap: 1rem;
            cursor: pointer;
            list-style: none;
        }

        .album:hover .album-title { color: #ccc; }

        .album-info { flex: 1; min-width: 0; }

        .album-title {
            font-size: 1rem;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .album-meta {
            font-size: 0.8rem;
            color: #777;
            margin-top: 0.2rem;
        }

        .album-expand { color: #555; font-size: 0.9rem; flex-shrink: 0; }

        /* ── Album tracks (expanded) ── */

        .album-tracks {
            display: none;
            padding: 0 0 0.25rem 1rem;
            border-bottom: 1px solid #1e1e1e;
            list-style: none;
        }

        .album-tracks.open { display: block; }

        /* ── Shared button style ── */

        .btn {
            padding: 0.3rem 0.65rem;
            border-radius: 5px;
            border: none;
            background: #2a2a2a;
            color: #eee;
            font-size: 0.8rem;
            cursor: pointer;
            white-space: nowrap;
        }

        .btn:hover { background: #383838; }
        .btn:disabled { opacity: 0.5; cursor: default; }
        .btn.confirm { color: #7dba84; }

        /* ── Queue panel ── */

        .queue-panel {
            position: fixed;
            top: 0;
            bottom: 0;
            left: 0;
            right: 0;
            overflow-y: auto;
            background: #111;
            display: none;
            padding: 0.75rem 1rem;
            z-index: 10;
        }

        .queue-panel.open { display: block; }

        .queue-panel ol {
            max-width: 640px;
            margin: 0 auto;
            padding-left: 1.5rem;
        }

        .queue-panel li {
            display: flex;
            align-items: center;
            padding: 0.4rem 0;
            border-bottom: 1px solid #222;
            font-size: 0.875rem;
            gap: 0.75rem;
        }

        .queue-panel li .queue-track-info { flex: 1; min-width: 0; }
        .queue-panel li span { color: #777; font-size: 0.8rem; display: block; margin-top: 0.1rem; }

        /* ── Now playing bar ── */

        .now-playing {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: #1a1a1a;
            border-top: 1px solid #2a2a2a;
            display: flex;
            flex-direction: column;
            padding: 0.5rem 1.25rem 0.4rem;
            gap: 0.35rem;
        }

        /* Seek row */

        .seek-row {
            display: flex;
            align-items: center;
            gap: 0.6rem;
        }

        .seek-time {
            font-size: 0.7rem;
            color: #555;
            flex-shrink: 0;
            width: 2.8rem;
        }

        .seek-time.right { text-align: right; }

        /* Controls row */

        .controls-row {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex-wrap: wrap;
        }

        .now-playing-info {
            width: 100%;
            min-width: 0;
        }

        .now-playing-title {
            font-size: 0.9rem;
            font-weight: 500;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .now-playing-artist {
            font-size: 0.75rem;
            color: #777;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .now-playing-album {
            font-size: 0.7rem;
            color: #555;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

        .now-playing-quality {
            font-size: 0.65rem;
            color: #444;
            margin-top: 0.1rem;
        }

        .playback-controls {
            display: flex;
            align-items: center;
            gap: 0.5rem;
            flex: 1;
        }

        .playback-controls .btn {
            font-size: 1rem;
            padding: 0.35rem 0.7rem;
        }

        .volume-wrap {
            display: flex;
            align-items: center;
            gap: 0.5rem;
        }

        .volume-wrap label { font-size: 0.75rem; color: #555; }

        input[type=range] {
            -webkit-appearance: none;
            height: 4px;
            border-radius: 2px;
            background: #333;
            outline: none;
            cursor: pointer;
        }

        input[type=range]::-webkit-slider-thumb {
            -webkit-appearance: none;
            width: 12px;
            height: 12px;
            border-radius: 50%;
            background: #aaa;
        }

        #seekBar { flex: 1; width: 100%; }
        #volumeSlider { width: 80px; }

    </style>
</head>
<body>

<form class="search-bar" action="/search" method="get">
    <input
        type="text"
        name="q"
        value="{{ query|e }}"
        placeholder="Search for a track…"
        autofocus
    >
    <button type="submit">Search</button>
</form>

{% if searched %}
    {% set hasTracks  = result and result.tracks is not empty %}
    {% set hasAlbums  = result and result.albums is not empty %}
    {% set hasStations = result and result.stations is not empty %}

    {% if not hasTracks and not hasAlbums and not hasStations %}
        <p class="no-results">No results found for "{{ query|e }}".</p>
    {% else %}
        <div class="tabs">
            <button class="tab active" onclick="setTab('all', this)">All</button>
            <button class="tab" onclick="setTab('tracks', this)">Tracks</button>
            <button class="tab" onclick="setTab('albums', this)">Albums</button>
            <button class="tab" onclick="setTab('radio', this)">Radio</button>
        </div>

        {% if hasTracks %}
        <div id="section-tracks">
            <div class="section-heading">Tracks</div>
            <ul class="results">
                {% for track in result.tracks %}
                    <li class="track"
                        data-track-id="{{ track.id|e }}"
                        data-source="{{ track.source|e }}"
                        data-title="{{ track.title|e }}"
                        data-artist="{{ track.artist|e }}"
                        data-album="{{ track.album|e }}">
                        <div class="track-info">
                            <div class="track-title">{{ track.title }}</div>
                            <div class="track-meta">{{ track.artist }} &mdash; {{ track.album }}</div>
                            <span class="source-badge {{ track.source }}">
                                {{- track.source == 'tidal' ? 'Tidal' : 'YT Music' -}}
                            </span>
                        </div>
                        <span class="track-duration">{{ track.formattedDuration() }}</span>
                        <div class="track-actions">
                            <button class="btn play-btn" onclick="playTrack(this)">▶</button>
                            <button class="btn queue-btn" onclick="queueTrack(this)">+ Queue</button>
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        {% if hasStations %}
        <div id="section-radio" style="margin-top: 1.5rem">
            <div class="section-heading">Radio</div>
            <ul class="results">
                {% for station in result.stations %}
                    <li class="track"
                        data-stream-url="{{ station.streamUrl|e }}"
                        data-saved-id="{{ station.savedId ?? '' }}"
                        data-name="{{ station.name|e }}"
                        data-genre="{{ station.genre|e }}">
                        <div class="track-info">
                            <div class="track-title">{{ station.name }}</div>
                            <div class="track-meta">{{ station.genre }} &mdash; Live</div>
                        </div>
                        <div class="track-actions">
                            <button class="btn play-btn" onclick="playRadio(this)">▶</button>
                            {% if station.isAdded %}
                                <span class="btn" style="background:transparent;color:#5a5;cursor:default">✓ Added</span>
                            {% else %}
                                <button class="btn" onclick="addStation(this)">+ Add</button>
                            {% endif %}
                        </div>
                    </li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}

        {% if hasAlbums %}
        <div id="section-albums" style="margin-top: 1.5rem">
            <div class="section-heading">Albums</div>
            <ul class="results">
                {% for album in result.albums %}
                    <li class="album"
                        data-album-id="{{ album.id|e }}"
                        data-source="{{ album.source|e }}"
                        onclick="toggleAlbum(this)">
                        <div class="album-info">
                            <div class="album-title">{{ album.title }}</div>
                            <div class="album-meta">{{ album.artist }} &mdash; {{ album.numTracks }} tracks</div>
                        </div>
                        <button class="btn" onclick="queueAlbum(this, event)">+ Queue All</button>
                        <span class="album-expand">▸</span>
                    </li>
                    <li class="album-tracks" id="album-tracks-{{ album.id|e }}"></li>
                {% endfor %}
            </ul>
        </div>
        {% endif %}
    {% endif %}
{% endif %}

<!-- Queue panel — slides up above the now-playing bar -->
<div class="queue-panel" id="queuePanel">
    <ol id="queueList"></ol>
</div>

<!-- Now playing bar — fixed to the bottom of the viewport -->
<div class="now-playing" id="nowPlayingBar">
    <div class="now-playing-info">
        <div class="now-playing-title" id="npTitle">—</div>
        <div class="now-playing-artist" id="npArtist"></div>
        <div class="now-playing-album" id="npAlbum"></div>
        <div class="now-playing-quality" id="npQuality"></div>
    </div>

    <div class="seek-row">
        <span class="seek-time" id="seekElapsed">0:00</span>
        <input type="range" id="seekBar" min="0" max="0" value="0">
        <span class="seek-time right" id="seekDuration">0:00</span>
    </div>

    <div class="controls-row">
        <div class="playback-controls">
            <button class="btn" onclick="sendCommand('/playback/previous')">⏮</button>
            <button class="btn" id="playPauseBtn" onclick="sendCommand('/playback/pause')">⏸</button>
            <button class="btn" onclick="sendCommand('/playback/stop')">⏹</button>
            <button class="btn" onclick="sendCommand('/playback/next')">⏭</button>
        </div>

        <div class="volume-wrap">
            <label for="volumeSlider">vol</label>
            <input type="range" id="volumeSlider" min="0" max="100" value="80">
        </div>

        <button class="btn" id="queueToggle" onclick="toggleQueue()">Queue (0)</button>
        <button class="btn" onclick="clearQueue()">Clear</button>
    </div>
</div>

<script>
    // ── State ──────────────────────────────────────────────────────────────

    let queueOpen         = false;
    let isSeeking         = false;  // true while the user is dragging the seek bar
    let isAdjustingVolume = false;  // true while the user is interacting with the volume slider
    const albumTracksCache = new Map(); // keyed by album id — avoids re-fetching on queue-all

    // ── Playback commands ──────────────────────────────────────────────────

    async function sendCommand(path) {
        await fetch(path, { method: 'POST' });
    }

    async function playTrack(btn) {
        const li = btn.closest('[data-track-id]');
        const payload = {
            track_id: li.dataset.trackId,
            source:   li.dataset.source,
            title:    li.dataset.title  || null,
            artist:   li.dataset.artist || null,
            album:    li.dataset.album  || null,
        };

        btn.disabled = true;

        const res = await fetch('/playback/play', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });

        if (res.ok) {
            btn.textContent = 'Playing…';
            btn.classList.add('confirm');
            setTimeout(() => {
                btn.textContent = '▶';
                btn.classList.remove('confirm');
                btn.disabled = false;
            }, 1500);
        } else {
            btn.textContent = 'Error';
            setTimeout(() => { btn.textContent = '▶'; btn.disabled = false; }, 1500);
        }
    }

    async function queueTrack(btn) {
        const li = btn.closest('[data-track-id]');
        const payload = {
            track_id: li.dataset.trackId,
            source:   li.dataset.source,
            title:    li.dataset.title  || null,
            artist:   li.dataset.artist || null,
            album:    li.dataset.album  || null,
        };

        btn.disabled = true;

        const res = await fetch('/playback/queue', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });

        if (res.ok) {
            btn.textContent = 'Queued';
            btn.classList.add('confirm');
            setTimeout(() => {
                btn.textContent = '+ Queue';
                btn.classList.remove('confirm');
                btn.disabled = false;
            }, 1500);

            // Refresh the queue panel if it's open so the new track appears.
            if (queueOpen) loadQueue();
        } else {
            btn.textContent = 'Error';
            setTimeout(() => { btn.textContent = '+ Queue'; btn.disabled = false; }, 1500);
        }
    }

    async function clearQueue() {
        await fetch('/playback/clear-queue', { method: 'POST' });
        updateQueueToggle(0);
        if (queueOpen) loadQueue();
    }

    // ── Tabs ──────────────────────────────────────────────────────────────

    function setTab(tab, btn) {
        document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
        btn.classList.add('active');

        const tracksSection = document.getElementById('section-tracks');
        const albumsSection = document.getElementById('section-albums');
        const radioSection  = document.getElementById('section-radio');

        if (tracksSection) tracksSection.style.display = (tab === 'all' || tab === 'tracks') ? '' : 'none';
        if (albumsSection) albumsSection.style.display = (tab === 'all' || tab === 'albums') ? '' : 'none';
        if (radioSection)  radioSection.style.display  = (tab === 'all' || tab === 'radio')  ? '' : 'none';
    }

    async function playRadio(btn) {
        const li      = btn.closest('[data-stream-url]');
        const savedId = li.dataset.savedId;
        const payload = savedId
            ? { station_id: parseInt(savedId) }
            : { stream_url: li.dataset.streamUrl };

        btn.disabled = true;

        const res = await fetch('/playback/radio', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(payload),
        });

        if (res.ok) {
            btn.textContent = '✓';
            setTimeout(() => { btn.textContent = '▶'; btn.disabled = false; }, 1500);
        } else {
            btn.textContent = 'Error';
            setTimeout(() => { btn.textContent = '▶'; btn.disabled = false; }, 1500);
        }
    }

    async function addStation(btn) {
        const li = btn.closest('[data-stream-url]');

        btn.disabled = true;
        btn.textContent = 'Adding…';

        const res = await fetch('/radio', {
            method: 'POST',
            headers: { 'Content-Type': 'application/x-www-form-urlencoded' },
            body: new URLSearchParams({
                name:       li.dataset.name,
                stream_url: li.dataset.streamUrl,
                genre:      li.dataset.genre,
            }),
        });

        if (res.ok || res.redirected) {
            btn.textContent = '✓ Added';
            btn.style.background = 'transparent';
            btn.style.color = '#5a5';
            btn.style.cursor = 'default';
            btn.onclick = null;
            li.dataset.savedId = '';  // will be populated on next search
        } else {
            btn.textContent = 'Error';
            btn.disabled = false;
        }
    }

    // ── Album tracks ───────────────────────────────────────────────────────

    async function fetchAlbumTracks(albumId, source) {
        if (albumTracksCache.has(albumId)) {
            return albumTracksCache.get(albumId);
        }

        const res = await fetch(`/search/album/${albumId}/tracks?source=${source}`);
        if (!res.ok) return null;

        const tracks = await res.json();
        albumTracksCache.set(albumId, tracks);
        return tracks;
    }

    async function toggleAlbum(li) {
        const albumId  = li.dataset.albumId;
        const source   = li.dataset.source;
        const arrow    = li.querySelector('.album-expand');
        const tracksEl = document.getElementById(`album-tracks-${albumId}`);
        const isOpen   = tracksEl.classList.contains('open');

        if (isOpen) {
            tracksEl.classList.remove('open');
            arrow.textContent = '▸';
            return;
        }

        if (!tracksEl.dataset.loaded) {
            arrow.textContent = '…';

            const tracks = await fetchAlbumTracks(albumId, source);

            if (!tracks) {
                arrow.textContent = '▸';
                return;
            }

            tracksEl.innerHTML = tracks.map(t => `
                <div class="track" data-track-id="${t.id}" data-source="${t.source}" data-title="${t.title}" data-artist="${t.artist}" data-album="${t.album ?? ''}">
                    <div class="track-info">
                        <div class="track-title">${t.title}</div>
                        <div class="track-meta">${t.artist}</div>
                        <span class="source-badge ${t.source}">${t.source === 'tidal' ? 'Tidal' : 'YT Music'}</span>
                    </div>
                    <span class="track-duration">${t.duration}</span>
                    <div class="track-actions">
                        <button class="btn play-btn" onclick="playTrack(this)">▶</button>
                        <button class="btn queue-btn" onclick="queueTrack(this)">+ Queue</button>
                    </div>
                </div>
            `).join('');

            tracksEl.dataset.loaded = '1';
        }

        tracksEl.classList.add('open');
        arrow.textContent = '▾';
    }

    async function queueAlbum(btn, event) {
        event.stopPropagation();

        const li      = btn.closest('.album');
        const albumId = li.dataset.albumId;
        const source  = li.dataset.source;

        btn.disabled = true;
        btn.textContent = '…';

        const tracks = await fetchAlbumTracks(albumId, source);

        if (!tracks) {
            btn.textContent = '+ Queue All';
            btn.disabled = false;
            return;
        }

        for (const track of tracks) {
            await fetch('/playback/queue', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ track_id: track.id, source: track.source, title: track.title, artist: track.artist, album: track.album ?? null }),
            });
        }

        btn.textContent = 'Queued';
        btn.classList.add('confirm');
        setTimeout(() => {
            btn.textContent = '+ Queue All';
            btn.classList.remove('confirm');
            btn.disabled = false;
        }, 1500);

        if (queueOpen) loadQueue();
    }

    // ── Status polling ─────────────────────────────────────────────────────

    async function pollStatus() {
        try {
            const res = await fetch('/playback/status');
            if (!res.ok) return;

            const status = await res.json();

            updateNowPlaying(status);
            updateQueueToggle(status.playlistlength ?? 0);
        } catch (_) {
            // Network error — silently skip this tick.
        }
    }

    function updateNowPlaying(status) {
        const state    = status.state ?? 'stop';
        const elapsed  = parseFloat(status.elapsed ?? 0);
        const duration = parseFloat(status.duration ?? 0);

        document.getElementById('playPauseBtn').textContent = state === 'play' ? '⏸' : '▶';

        if (status.title) {
            document.getElementById('npTitle').textContent  = status.title;
            document.getElementById('npArtist').textContent = status.artist ?? '';

            const albumParts = [status.album, status.date].filter(Boolean);
            document.getElementById('npAlbum').textContent = albumParts.join(' · ');

            document.getElementById('npQuality').textContent = formatAudioQuality(status.audio, status.bitrate);
        } else if (state === 'stop') {
            document.getElementById('npTitle').textContent   = '—';
            document.getElementById('npArtist').textContent  = '';
            document.getElementById('npAlbum').textContent   = '';
            document.getElementById('npQuality').textContent = '';
        }

        updateSeekBar(elapsed, duration);

        if (status.volume !== undefined && !isAdjustingVolume) {
            document.getElementById('volumeSlider').value = status.volume;
        }
    }

    function formatAudioQuality(audio, bitrate) {
        if (!audio && !bitrate) return '';

        const parts = [];

        if (audio) {
            const [sampleRate, bits] = audio.split(':');
            const khz = (parseInt(sampleRate) / 1000).toFixed(1);
            parts.push(`${khz}kHz`);
            if (bits && bits !== '0') parts.push(`${bits}-bit`);
        }

        if (bitrate) parts.push(`${bitrate}kbps`);

        return parts.join(' · ');
    }

    function updateSeekBar(elapsed, duration) {
        const bar = document.getElementById('seekBar');

        bar.max = duration || 0;

        // Don't move the thumb while the user is dragging — it would fight them.
        if (!isSeeking) {
            bar.value = elapsed;
        }

        document.getElementById('seekElapsed').textContent  = formatTime(elapsed);
        document.getElementById('seekDuration').textContent = formatTime(duration);
    }

    function formatTime(seconds) {
        if (!seconds || isNaN(seconds)) return '0:00';
        const m = Math.floor(seconds / 60);
        const s = Math.floor(seconds % 60);
        return `${m}:${s.toString().padStart(2, '0')}`;
    }

    function updateQueueToggle(length) {
        document.getElementById('queueToggle').textContent = `Queue (${length})`;
    }

    // Poll every 2 seconds so the now-playing bar stays current.
    setInterval(pollStatus, 2000);
    pollStatus(); // run immediately on page load

    // ── Queue panel ────────────────────────────────────────────────────────

    async function loadQueue() {
        const res = await fetch('/playback/queue');
        if (!res.ok) return;

        const tracks = await res.json();
        const list = document.getElementById('queueList');

        if (tracks.length === 0) {
            list.innerHTML = '<li style="color:#555">Queue is empty.</li>';
            return;
        }

        list.innerHTML = tracks.map(t => {
            const meta = [t.artist, t.album].filter(Boolean).join(' — ');
            return `<li>
                <div class="queue-track-info">
                    ${t.title ?? 'Unknown'}
                    ${meta ? `<span>${meta}</span>` : ''}
                </div>
                <button class="btn" onclick="removeFromQueue(${t.id}, this)">Remove</button>
            </li>`;
        }).join('');
    }

    async function removeFromQueue(songId, btn) {
        btn.disabled = true;
        const res = await fetch(`/playback/queue/${songId}`, { method: 'DELETE' });
        if (res.ok) {
            btn.closest('li').remove();
        } else {
            btn.disabled = false;
        }
    }

    function setQueuePanelBottom() {
        const bar   = document.getElementById('nowPlayingBar');
        const panel = document.getElementById('queuePanel');
        panel.style.bottom = bar.offsetHeight + 'px';
    }

    function toggleQueue() {
        const panel = document.getElementById('queuePanel');
        queueOpen = !queueOpen;
        setQueuePanelBottom();
        panel.classList.toggle('open', queueOpen);

        // Load queue contents each time the panel is opened.
        if (queueOpen) loadQueue();
    }

    window.addEventListener('resize', () => { if (queueOpen) setQueuePanelBottom(); });

    // ── Seek bar ───────────────────────────────────────────────────────────

    const seekBar = document.getElementById('seekBar');

    // While dragging, update the elapsed display so the user sees where they're
    // heading, but don't send a command yet.
    seekBar.addEventListener('input', function () {
        isSeeking = true;
        document.getElementById('seekElapsed').textContent = formatTime(parseInt(this.value));
    });

    // Send the seek command when the user releases the thumb.
    seekBar.addEventListener('change', function () {
        fetch('/playback/seek', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ position: parseInt(this.value) }),
        }).finally(() => { isSeeking = false; });
    });

    // ── Volume slider ──────────────────────────────────────────────────────

    // Debounced so we don't flood MPD with setvol commands while the user
    // is dragging — the slider fires 'input' continuously during drag.
    let volumeTimer = null;

    document.getElementById('volumeSlider').addEventListener('input', function () {
        isAdjustingVolume = true;
        clearTimeout(volumeTimer);
        volumeTimer = setTimeout(() => {
            fetch('/playback/volume', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify({ volume: parseInt(this.value) }),
            }).finally(() => { isAdjustingVolume = false; });
        }, 140);
    });
</script>

</body>
</html>
