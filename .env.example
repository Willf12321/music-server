APP_ENV=dev
APP_SECRET=
APP_SHARE_DIR=var/share
DEFAULT_URI=http://localhost
SIDECAR_URL=http://python-sidecar:8001
MPD_HOST=mpd
MPD_PORT=6600
STREAM_BASE_URL=http://nginx

# ALSA device and mixer for MPD audio output.
# Run `aplay -l` on the host to find the correct device.
# Dev laptop:  MPD_AUDIO_DEVICE=plughw:1,2  MPD_MIXER_TYPE=software
# NUC:         MPD_AUDIO_DEVICE=hw:0,0      MPD_MIXER_TYPE=hardware
MPD_AUDIO_DEVICE=plughw:1,2
MPD_MIXER_TYPE=software
